{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install: Frontend deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Install: Backend deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Run: Frontend (Vite dev server)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run: Backend (Express API)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run: Both (frontend + backend)",
      "dependsOn": ["Run: Frontend (Vite dev server)", "Run: Backend (Express API)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
