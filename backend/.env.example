# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fraud_shield

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace_with_another_long_random_string

# File storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI providers (server-side only — never exposed to frontend)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional cache / realtime scaling
REDIS_URL=redis://localhost:6379

# Cyber crime helpline shown in citizen-facing responses
NATIONAL_HELPLINE=1930
